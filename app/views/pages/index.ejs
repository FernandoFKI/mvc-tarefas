<!DOCTYPE html>
<html lang="pt-br">

<head>
    <meta charset="UTF-8">
    <meta http-equiv="X-UA-Compatible" content="IE=edge">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Modelo App Node</title>
    <style>
        body { font-family: Arial, sans-serif; padding: 20px; }
        table { border-collapse: collapse; width: 100%; margin-top: 10px; }
        th, td { border: 1px solid #ccc; padding: 8px 12px; text-align: left; }
        th { background-color: #f0f0f0; }
        a { margin-right: 8px; }
        a.excluir { color: #c0392b; }
        button { margin-bottom: 10px; padding: 8px 14px; cursor: pointer; }
    </style>
</head>

<body>
    <h1>Lista de Tarefas</h1>
    <button type="button" onclick="window.location='/nova-tarefa'">Nova Tarefa</button>

    <table>
        <thead>
            <tr>
                <th>Código</th>
                <th>Tarefa</th>
                <th>Prazo</th>
                <th>Situação</th>
                <th>Ações</th>
            </tr>
        </thead>
        <tbody>
        <%
            let situacao = ["Cancelada", "Pendente", "Iniciada", "Finalizada", "Atrasada"];
            if (linhasTabela && linhasTabela.length > 0) {
                linhasTabela.forEach((item) => {
        %>
            <tr>
                <td><%= item.id_tarefa %></td>
                <td><%= item.nome_tarefa %></td>
                <td><%= moment(item.prazo_tarefa).format('L') %></td>
                <td><%= situacao[item.situacao_tarefa] %></td>
                <td>
                    <a href="/editar?id=<%= item.id_tarefa %>">Editar</a>
                    <a class="excluir"
                       href="/excluir-logico?id=<%= item.id_tarefa %>"
                       onclick="return confirm('Deseja realmente excluir esta tarefa?')">
                        Excluir
                    </a>
                </td>
            </tr>
        <%
                });
            } else {
        %>
            <tr>
                <td colspan="5">Sem tarefas para exibir.</td>
            </tr>
        <%
            }
        %>
        </tbody>
    </table>
</body>

</html>
